# Environment contract for the About Me page (src/app/about + src/app/api/*).
# Copy to `.env.local` (git-ignored) and fill in. Add the same vars to Vercel.
# Every integration degrades gracefully when its vars are absent, so the page
# still renders in local dev with nothing set (voice falls back to the browser's
# built-in speech; chat/contact return a clear "not configured" error).

# ---- AI chat — Google Gemini 2.5 Flash (free tier) -------------------------
# Free key: https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# ---- Voice — ElevenLabs (paid: TTS for Juniel's voice + STT via Scribe) -----
# https://elevenlabs.io → Profile → API key. SET A MONTHLY CREDIT CAP.
ELEVENLABS_API_KEY=
# A voice id from your ElevenLabs Voices library — the voice Juniel speaks in.
ELEVENLABS_VOICE_ID=

# ---- Contact form — Resend --------------------------------------------------
# https://resend.com → verify your domain (DNS records) → create an API key.
RESEND_API_KEY=
# Sender — MUST be an address on your Resend-verified domain.
CONTACT_FROM_EMAIL=about@yourdomain.com
# Recipient — where contact messages are delivered.
CONTACT_TO_EMAIL=junieldjossou@gmail.com

# ---- Rate limiting (optional, recommended) ----------------------------------
# Free Redis: https://upstash.com. Without these, a relaxed in-memory limiter is
# used (fine for local dev; per-instance only in production).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
